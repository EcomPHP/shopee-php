{
  "name": "ecomphp/shopee-php",
  "description": "A powerful, lightweight, and developer-friendly Shopee API PHP SDK designed to integrate Shopee Open Platform v2 into vanilla PHP applications, Laravel, or Symfony projects.",
  "type": "library",
  "bin": [
    "bin/shopee-mcp-server",
    "bin/shopee-mcp-install",
    "bin/shopee-openapi-announcement"
  ],
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "nVuln",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^7.2|^8.0",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^8|^9"
  },
  "autoload": {
    "psr-4": {
      "EcomPHP\\Shopee\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "EcomPHP\\Shopee\\Tests\\": "tests"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "mcp": "bin/shopee-mcp-server"
  }
}
